{
  "name": "@naikamu/mobile",
  "version": "0.17.4",
  "codeVersion": "80",
  "apiVersion": "1.5.x",
  "private": true,
  "engines": {
    "node": "22.21.1"
  },
  "engineStrict": true,
  "scripts": {
    "android:dev": "expo run:android --variant developmentdebug",
    "android:dev:release": "expo run:android --variant developmentrelease",
    "android:staging": "expo run:android --variant stagingdebug",
    "android:staging:release": "expo run:android --variant stagingrelease",
    "android:prod": "expo run:android --variant productiondebug",
    "android:prod:release": "expo run:android --variant productionrelease",
    "ios:dev": "expo run:ios --configuration Debug --scheme NaikamuDev --no-build-cache --device \"iPhone 17\"",
    "ios:dev:release": "expo run:ios --configuration Release --scheme NaikamuDev --no-build-cache --device \"iPhone 17\"",
    "ios:stg:release": "expo run:ios --configuration Release --scheme NaikamuStg",
    "ios:prod:release": "expo run:ios --configuration Release --scheme Naikamu --device \"iPhone 17 Pro Max\"",
    "pod": "npx pod-install ios",
    "start": "expo start -c",
    "start:clear": "cd android && ./gradlew clean && cd .. && expo start -c",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "app:release": "cd android && ./gradlew bundleRelease",
    "apk:beta:release": "cd android && fastlane beta && cd .. && npm run apk:beta:rename && open android/app/build/outputs/apk/production/release",
    "apk:release:stg": "./release.sh -e stg",
    "apk:release:prod": "./release.sh -e prod",
    "apk:remove_assets": "rm -rf ./android/app/build/generated/assets"
  },
  "dependencies": {
